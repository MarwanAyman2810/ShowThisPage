{
    "compilerOptions": {
      "target": "ES6",                          // Modern JavaScript version
      "module": "ESNext",                       // Module system
      "strict": true,                           // Enable all strict type-checking options
      "outDir": "./dist",                       // Output directory for compiled JS files
      "esModuleInterop": true,                  // Compatibility with CommonJS modules
      "forceConsistentCasingInFileNames": true, // Consistent file naming
      "skipLibCheck": true,                     // Skip type checking of declaration files
      "types": ["chrome"],                      // Include Chrome type definitions
      "sourceMap": true                         // Enable source maps for debugging
    },
    "include": ["background.js",
 "content.ts",
 "manifest.json",
 "notes.js",
 "package-lock.json",
 "package.json",
 "popup.html",
 "popup.ts",
 "README.md",
  "tsconfig.json"
 ]                    // Include all TypeScript files in src/
  }
  